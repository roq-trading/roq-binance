{
  "name": "REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "network_interfaces",
      "type": "std::vector<std::string>",
      "description": "List of REST network interfaces"
    },
    {
      "name": "uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "https://testnet.binance.com",
      "description": "REST end-point (URI)"
    },
    {
      "name": "host",
      "type": "std::string",
      "description": "Host (HTTP header) to use when the URI configured with IP address"
    },
    {
      "name": "proxy",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "description": "REST proxy end-point (URI)"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std::string",
      "validator": "roq::flags::validators::Path",
      "default": "/api/v3/time",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Request timeout"
    },
    {
      "name": "terminate_on_403",
      "type": "bool",
      "default": false,
      "description": "Terminate after getting a 403 response code"
    },
    {
      "name": "back_off_delay",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "300s",
      "description": "Time to wait before retrying a rejected request"
    },
    {
      "name": "listen_key_refresh",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "1800s",
      "description": "Listen key refresh period"
    },
    {
      "name": "order_recv_window",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5000ms",
      "description": "Receive window (please refer to Binance documentation)"
    },
    {
      "name": "cancel_on_disconnect",
      "type": "bool",
      "default": false,
      "description": "Cancel orders on disconnect?"
    }
  ]
}
