{
  "name": "WS",
  "type": "flags",
  "prefix": "ws_",
  "values": [
    {
      "name": "uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://testnet.binance.com/realtime",
      "description": "WebSocket end-point (URI)"
    },
    {
      "name": "host",
      "type": "std::string",
      "description": "Host (HTTP header) to use when the URI configured with IP address"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "max_subscriptions_per_stream",
      "type": "uint32_t",
      "required": true,
      "default": 128,
      "description": "Maximum number of symbols per connection"
    },
    {
      "name": "subscribe_depth_levels",
      "type": "uint32_t",
      "default": 1000,
      "description": "Pepth levels (count)"
    },
    {
      "name": "subscribe_depth_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "100ms",
      "description": "Depth update frequency"
    },
    {
      "name": "mbp_request_delay",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "10s",
      "description": "Request delay"
    },
    {
      "name": "mbp_request_max_retries",
      "type": "uint32_t",
      "default": 0,
      "description": "Request max retries"
    },
    {
      "name": "subscribe_trade_details",
      "type": "bool",
      "default": false,
      "description": "Report individual matches for trade summary? (bool)"
    },
    {
      "name": "enable_secondary",
      "type": "bool",
      "default": false,
      "description": "Create secondary market data connection? (bool)"
    }
  ]
}
