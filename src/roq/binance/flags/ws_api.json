{
  "name": "WS_API",
  "type": "flags",
  "prefix": "ws_api_",
  "values": [
    {
      "name": "network_interfaces",
      "type": "std::vector<std::string>",
      "description": "WebSocket API network interfaces"
    },
    {
      "name": "uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://ws-api.binance.com/ws-api/v3",
      "description": "WebSocket API end-point (URI)"
    },
    {
      "name": "host",
      "type": "std::string",
      "description": "host (http header) in case uri uses an IP address"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    }
  ]
}
